# OpenClaw Project Security - Ignore List
# 核心敏感資訊
.env
api_keys_config.json
*.pem
*.key
secrets/
.env.local
scripts/blogger/token.json
scripts/blogger/client_secret.json
drafts/
content_queue.local.json
__pycache__/
*.pyc

# 開發臨時腳本 (可能包含測試金鑰)
quick_add.py
test_*.py
check_*.py
*test_key*
*temp*

# 系統日誌與追蹤
logs/
*.log
memory/reports/
node_modules/
.DS_Store

# 瀏覽器會話數據
.openclaw/browser_data/
localStorage/
cookies.json

# Public repository / deployment boundary
# Keep internal agent memory, SOPs, automation scripts, logs, drafts, and source-only assets local.
/*.md
/CARKEY_AGENT_MAINTENANCE_PLAYBOOK.md
/memory/
/ops/
/posts/
/backup/
/backups/
/drafts/
/local/
/logs/
/seo_data/
/busan_doc/
/claude_integration/
/.openclaw/
/.codex-remote-attachments/
/.uv-cache/
/.uv-python/
/vid/

# Internal automation and private platform tooling
/*.py
/scripts/*.py
/scripts/blogger/
/scripts/content_automation/
/scripts/discord/
/scripts/google_business_profile/
/scripts/hermes/

# Root-only source photos and archive artifacts
/*.jpg
/*.JPG
/*.jpeg
/*.JPEG
/*.png
/*.PNG
/*.HEIC
/*.zip
/*.bak
/*.pre_fix
/*.test
/file_list*.txt
/subfolder_list.txt
/sitemap_local.xml

# Local runtime metadata (may contain credentials)
.codex_flywheel_materialized.json
