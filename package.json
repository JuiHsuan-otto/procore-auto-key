{
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i ./assets/css/tailwind-source.css -o ./assets/css/tailwind-procore.css --minify",
    "seo:breadcrumbs": "node scripts/apply-breadcrumb-structured-data.mjs",
    "optimize:images": "node scripts/optimize-referenced-images.mjs",
    "audit:measurement": "node scripts/audit-measurement.mjs",
    "report:ga-gsc": "node scripts/reconcile-ga-gsc.mjs",
    "seo:inventory": "node scripts/generate-seo-inventory.mjs",
    "seo:baseline": "node scripts/check-production-baseline.mjs",
    "validate:governance": "node scripts/validate-seo-governance.mjs",
    "validate:seo-pilot": "node scripts/validate-schema-image-pilot.mjs",
    "test:seo-foundation": "node scripts/test-seo-foundation.mjs && node scripts/generate-seo-inventory.mjs --check && node scripts/validate-seo-governance.mjs --self-test && node scripts/validate-schema-image-pilot.mjs --self-test",
    "validate:site": "node scripts/validate-static-site.mjs"
  },
  "dependencies": {
    "canvas": "^3.2.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
